{% extends 'layout/admin.html.twig' %}

{% block content %}
<div class="p-6">
    <h1 class="text-2xl font-bold mb-6">Couveuses</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for couveuse in couveuses %}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="p-4 bg-gray-50 border-b border-gray-100">
                    <div class="flex items-center justify-between">
                        <h3 class="font-bold text-lg">{{ couveuse.nom }}</h3>
                        <span class="px-2 py-1 rounded-full text-xs font-semibold
                            {% if couveuse.statut == 'disponible' %}bg-green-100 text-green-800
                            {% elseif couveuse.statut == 'en_marche' %}bg-blue-100 text-blue-800
                            {% elseif couveuse.statut == 'maintenance' %}bg-yellow-100 text-yellow-800
                            {% else %}bg-red-100 text-red-800{% endif %}">
                            {{ couveuse.statut }}
                        </span>
                    </div>
                </div>
                <div class="p-4 space-y-2 text-sm">
                    <p><strong>Capacité :</strong> {{ couveuse.capacite }} œufs</p>
                    {% if couveuse.temperature %}
                        <p><strong>Température :</strong> {{ couveuse.temperature }} °C</p>
                    {% endif %}
                    {% if couveuse.humidite %}
                        <p><strong>Humidité :</strong> {{ couveuse.humidite }} %</p>
                    {% endif %}
                    <p><strong>Incubations :</strong> {{ couveuse.incubations|length }}</p>
                </div>
                <div class="p-3 border-t border-gray-100 bg-gray-50">
                    <a href="{{ path('app_manager_couveuse_detail', {'id': couveuse.id}) }}" class="text-sm font-semibold text-farmGreen hover:underline">
                        Voir les incubations →
                    </a>
                </div>
            </div>
        {% else %}
            <p class="col-span-full text-gray-500">Aucune couveuse.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}
