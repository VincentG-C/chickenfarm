{% extends 'layout/admin.html.twig' %}

{% block content %}
<div class="p-6">
    <a href="{{ path('app_manager_enclos') }}" class="text-sm text-gray-500 hover:text-gray-700 mb-6 inline-block">
        <i class="fa-solid fa-arrow-left mr-1"></i> Retour aux enclos
    </a>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
        <div class="flex items-center justify-between mb-4">
            <h1 class="text-2xl font-bold">{{ enclos.nom }}</h1>
            <span class="px-3 py-1 rounded-full text-sm font-semibold
                {% if enclos.type == 'poulailler' %}bg-green-100 text-green-800
                {% elseif enclos.type == 'enclos_exterieur' %}bg-blue-100 text-blue-800
                {% else %}bg-purple-100 text-purple-800{% endif %}">
                {{ enclos.type }}
            </span>
        </div>
        <p class="text-gray-600"><strong>Superficie :</strong> {{ enclos.superficie }} m²</p>
        <p class="text-gray-600"><strong>Capacité :</strong> {{ enclos.nbGallinaces }} / {{ enclos.capaciteMax }}</p>
    </div>

    <h2 class="text-xl font-bold mb-4">Gallinacés dans cet enclos ({{ enclos.gallinaces|length }})</h2>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="text-left px-4 py-3 font-semibold">Nom</th>
                    <th class="text-left px-4 py-3 font-semibold">Type</th>
                    <th class="text-left px-4 py-3 font-semibold">Âge</th>
                    <th class="text-left px-4 py-3 font-semibold">Poids</th>
                    <th class="text-left px-4 py-3 font-semibold">Santé</th>
                </tr>
            </thead>
            <tbody>
                {% for gallinace in enclos.gallinaces %}
                    <tr class="border-b border-gray-100 hover:bg-gray-50">
                        <td class="px-4 py-3 font-semibold">{{ gallinace.nom }}</td>
                        <td class="px-4 py-3">
                            {% if 'poule' in gallinace|class_name|lower %}
                                🐔 Poule
                            {% elseif 'coq' in gallinace|class_name|lower %}
                                🐓 Coq
                            {% elseif 'poussin' in gallinace|class_name|lower %}
                                🐤 Poussin
                            {% else %}
                                Gallinacé
                            {% endif %}
                        </td>
                        <td class="px-4 py-3">{{ gallinace.age }} mois</td>
                        <td class="px-4 py-3">{{ gallinace.poids }} kg</td>
                        <td class="px-4 py-3">
                            <span class="px-2 py-1 rounded-full text-xs font-semibold
                                {% if gallinace.sante == 'excellent' %}bg-green-100 text-green-800
                                {% elseif gallinace.sante == 'bon' %}bg-blue-100 text-blue-800
                                {% elseif gallinace.sante == 'moyen' %}bg-yellow-100 text-yellow-800
                                {% else %}bg-red-100 text-red-800{% endif %}">
                                {{ gallinace.sante }}
                            </span>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="px-4 py-8 text-center text-gray-500">Aucun gallinacé dans cet enclos.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
