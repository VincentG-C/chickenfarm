{% extends 'layout/admin.html.twig' %}

{% block content %}
<div class="p-6">
    <h1 class="text-2xl font-bold mb-6">Gestion des utilisateurs</h1>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="text-left px-4 py-3 font-semibold">Identité</th>
                    <th class="text-left px-4 py-3 font-semibold">Email</th>
                    <th class="text-left px-4 py-3 font-semibold">Rôle</th>
                    <th class="text-left px-4 py-3 font-semibold">Inscrit le</th>
                    <th class="text-left px-4 py-3 font-semibold">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr class="border-b border-gray-100 hover:bg-gray-50">
                        <td class="px-4 py-3 font-semibold">{{ user.prenom }} {{ user.nom }}</td>
                        <td class="px-4 py-3 text-gray-500">{{ user.email }}</td>
                        <td class="px-4 py-3">
                            <span class="px-2 py-1 rounded-full text-xs font-semibold
                                {% if user|class_name == 'Admin' %}bg-purple-100 text-purple-800
                                {% elseif user|class_name == 'Manager' %}bg-blue-100 text-blue-800
                                {% else %}bg-green-100 text-green-800
                                {% endif %}">
                                {{ user|class_name }}
                            </span>
                        </td>
                        <td class="px-4 py-3 text-gray-500">{{ user.createdAt|date('d/m/Y') }}</td>
                        <td class="px-4 py-3 flex gap-2">
                            <a href="{{ path('app_user_show', {'id': user.id}) }}" class="text-farmGreen font-semibold hover:underline text-sm">
                                <i class="fa-solid fa-eye"></i>
                            </a>
                            <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="text-farmGreen font-semibold hover:underline text-sm">
                                <i class="fa-solid fa-pen"></i>
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="px-4 py-8 text-center text-gray-500">Aucun utilisateur.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
