<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block email_title %}Ferme des Poulettes{% endblock %}</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f3f4f6; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">
    <table style="width: 100%; max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 12px; overflow: hidden;" cellpadding="0" cellspacing="0">
        <tr>
            <td style="background: linear-gradient(135deg, #d97706, #f59e0b); padding: 24px; text-align: center;">
                <img src="https://cdn-icons-png.flaticon.com/128/1406/1406917.png" alt="Ferme des Poulettes" width="64" height="64" style="display: block; margin: 0 auto 8px;">
                <h1 style="font-size: 20px; color: #ffffff; margin: 0;">🐔 Ferme des Poulettes</h1>
            </td>
        </tr>
        <tr>
            <td style="padding: 32px;">
                {% block email_content %}{% endblock %}
            </td>
        </tr>
        <tr>
            <td style="padding: 24px; background-color: #f9fafb; text-align: center; border-top: 1px solid #e5e7eb;">
                <p style="font-size: 12px; color: #9ca3af; margin: 0;">
                    Ferme des Poulettes &bull; Rue de la Basse-Cour &bull; 75000 Paris<br>
                    <a href="{{ url('app_home') }}" style="color: #d97706; text-decoration: none;">ferme-des-poulettes.fr</a>
                </p>
            </td>
        </tr>
    </table>
</body>
</html>
