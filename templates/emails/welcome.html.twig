{% extends 'emails/base.html.twig' %}

{% block email_title %}Bienvenue à la Ferme des Poulettes !{% endblock %}

{% block email_content %}
    <h1 style="font-size: 24px; margin: 0 0 20px; color: #1f2937;">Bonjour {{ user.prenom }},</h1>

    <p style="font-size: 16px; line-height: 1.6; color: #4b5563; margin: 0 0 16px;">
        Bienvenue à la <strong>Ferme des Poulettes</strong> ! Nous sommes ravis de vous compter parmi nous.
    </p>

    <p style="font-size: 16px; line-height: 1.6; color: #4b5563; margin: 0 0 16px;">
        Vous pouvez dès maintenant découvrir nos produits fermiers : œufs frais, volailles de qualité,
        visites de la ferme et bien plus encore.
    </p>

    <div style="text-align: center; margin: 30px 0;">
        <a href="{{ url('app_catalogue') }}" style="display: inline-block; background-color: #d97706; color: #ffffff; text-decoration: none; font-weight: bold; font-size: 16px; padding: 14px 32px; border-radius: 8px;">
            Découvrir la boutique
        </a>
    </div>

    <p style="font-size: 14px; line-height: 1.6; color: #9ca3af; margin: 0;">
        À très bientôt,<br>
        <strong>L'équipe de la Ferme des Poulettes</strong>
    </p>
{% endblock %}
