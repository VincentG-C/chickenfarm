{% extends 'layout/app.html.twig' %}

{% block content %}
<main class="max-w-4xl mx-auto px-6 md:px-12 py-8">
    <a href="{{ path('app_catalogue') }}" class="text-sm text-gray-500 hover:text-gray-700 mb-6 inline-block">
        <i class="fa-solid fa-arrow-left mr-1"></i> Retour au catalogue
    </a>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-eggShell rounded-2xl h-80 flex items-center justify-center text-8xl">
            {% if 'oeuf' in produit|class_name|lower %}
                <i class="fa-solid fa-egg text-brand"></i>
            {% elseif 'viande' in produit|class_name|lower %}
                <i class="fa-solid fa-drumstick-bite text-amber-700"></i>
            {% elseif 'ticket' in produit|class_name|lower %}
                <i class="fa-solid fa-ticket text-green-600"></i>
            {% elseif 'nourriture' in produit|class_name|lower %}
                <i class="fa-solid fa-seedling text-green-500"></i>
            {% else %}
                <i class="fa-solid fa-box text-gray-400"></i>
            {% endif %}
        </div>

        <div>
            <h1 class="text-3xl font-bold mb-2">{{ produit.nom }}</h1>
            <p class="text-2xl font-bold text-brand mb-4">{{ produit.prix }} €{% if produit.prixUnite %} / {{ produit.prixUnite }}{% endif %}</p>

            {% if produit.stock %}
                <p class="mb-4 {% if produit.stock.quantiteDisponible > 0 %}text-green-600{% else %}text-red-500{% endif %}">
                    {% if produit.stock.quantiteDisponible > 0 %}
                        <i class="fa-solid fa-circle-check"></i> En stock ({{ produit.stock.quantiteDisponible }} disponible(s))
                    {% else %}
                        <i class="fa-solid fa-circle-xmark"></i> Rupture de stock
                    {% endif %}
                </p>
            {% endif %}

            {% if produit.description %}
                <p class="text-gray-600 mb-6">{{ produit.description }}</p>
            {% endif %}

            {% if 'ticket' in produit|class_name|lower %}
                <div class="bg-gray-50 rounded-xl p-4 mb-6 text-sm">
                    <p><strong>Date de visite :</strong> {{ produit.dateVisite|date('d/m/Y') }}</p>
                    <p><strong>Durée :</strong> {{ produit.dureeVisite }} minutes</p>
                    <p><strong>Places restantes :</strong> {{ produit.nbPlacesRestantes }} / {{ produit.nbPlaces }}</p>
                </div>
            {% endif %}

            {% if is_granted('ROLE_USER') and produit.stock and produit.stock.quantiteDisponible > 0 %}
                <form action="{{ path('app_panier_ajouter', {'id': produit.id}) }}" method="POST" class="flex items-center gap-3">
                    <label for="quantite" class="text-sm font-semibold">Quantité :</label>
                    <input type="number" name="quantite" id="quantite" value="1" min="1" max="{{ produit.stock ? produit.stock.quantiteDisponible : 99 }}" class="w-20 border border-gray-300 rounded-lg px-3 py-2 text-center">
                    <button type="submit" class="bg-farmGreen text-white font-bold px-6 py-2.5 rounded-full hover:bg-farmGreenLight transition">
                        <i class="fa-solid fa-basket-shopping mr-1"></i> Ajouter au panier
                    </button>
                </form>
            {% elseif not is_granted('ROLE_USER') %}
                <a href="{{ path('app_login') }}" class="inline-block bg-farmGreen text-white font-bold px-6 py-2.5 rounded-full hover:bg-farmGreenLight transition">
                    Connectez-vous pour acheter
                </a>
            {% elseif produit.stock and produit.stock.quantiteDisponible <= 0 %}
                <p class="text-red-500 font-semibold">Cet article est actuellement en rupture de stock.</p>
            {% endif %}
        </div>
    </div>
</main>
{% endblock %}
