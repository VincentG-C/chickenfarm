{% extends 'layout/app.html.twig' %}

{% block content %}
<main class="max-w-4xl mx-auto px-6 md:px-12 py-8">
    <a href="{{ path('app_commandes') }}" class="text-sm text-gray-500 hover:text-gray-700 mb-6 inline-block">
        <i class="fa-solid fa-arrow-left mr-1"></i> Retour à mes commandes
    </a>

    <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
        <div class="bg-farmGreen text-white p-6">
            <h1 class="text-2xl font-bold">Commande #{{ commande.reference }}</h1>
            <p class="text-green-100">{{ commande.dateCommande|date('d/m/Y à H:i') }}</p>
            <p class="mt-2">
                {% set statuts = {'en_attente': 'En attente', 'confirmee': 'Confirmée', 'en_preparation': 'En préparation', 'expediee': 'Expédiée', 'livree': 'Livrée', 'annulee': 'Annulée'} %}
                <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold bg-white text-farmGreen">
                    {{ statuts[commande.statut] ?? commande.statut }}
                </span>
            </p>
        </div>

        <div class="p-6">
            <h2 class="font-bold text-lg mb-4">Détails de la commande</h2>

            <div class="space-y-3 mb-6">
                {% for detail in commande.details %}
                    <div class="flex items-center justify-between border-b border-gray-100 pb-3">
                        <div>
                            <span class="font-semibold">{{ detail.produit.nom }}</span>
                            <span class="text-gray-500 text-sm ml-2">× {{ detail.quantite }}</span>
                        </div>
                        <span class="font-semibold">{{ (detail.quantite * detail.prixUnitaire)|number_format(2) }} €</span>
                    </div>
                {% endfor %}
            </div>

            <div class="border-t border-gray-200 pt-4 flex justify-between text-xl font-bold">
                <span>Total</span>
                <span class="text-brand">{{ commande.montantTotal }} €</span>
            </div>

            {% if commande.livraison %}
                <div class="mt-6 bg-gray-50 rounded-xl p-4">
                    <h3 class="font-semibold mb-2">Livraison</h3>
                    <p class="text-sm text-gray-600">{{ commande.livraison.adresseLivraison }}</p>
                    <p class="text-sm text-gray-500">Prévue le {{ commande.livraison.dateLivraisonPrevue|date('d/m/Y') }}</p>
                </div>
            {% endif %}

            {% if commande.notes %}
                <div class="mt-4 text-sm text-gray-600">
                    <strong>Notes :</strong> {{ commande.notes }}
                </div>
            {% endif %}
        </div>
    </div>
</main>
{% endblock %}
