{% extends 'layout/app.html.twig' %}

{% block content %}
<main>
    {# Hero Section #}
    <section class="relative bg-farmGreen text-white py-20 px-6 md:px-12">
        <div class="max-w-5xl mx-auto text-center">
            <h1 class="text-4xl md:text-6xl font-bold mb-6">🐔 Bienvenue à la Ferme des Poulettes</h1>
            <p class="text-xl md:text-2xl mb-8 text-green-100">Des œufs frais, de la volaille de qualité, et des visites authentiques à la ferme</p>
            <div class="flex flex-wrap justify-center gap-4">
                <a href="{{ path('app_catalogue') }}" class="bg-white text-farmGreen font-bold px-8 py-3 rounded-full hover:bg-green-50 transition shadow-lg">
                    Découvrir nos produits
                </a>
                <a href="{{ path('app_catalogue') ~ '?type=ticket' }}" class="bg-transparent border-2 border-white text-white font-bold px-8 py-3 rounded-full hover:bg-white hover:text-farmGreen transition">
                    Visiter la ferme
                </a>
            </div>
        </div>
    </section>

    {# Featured Products #}
    <section class="py-12 px-6 md:px-12 max-w-6xl mx-auto">
        <h2 class="text-2xl font-bold mb-8 text-center">Nos produits</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            {% for produit in produits %}
                <div class="border border-gray-200 rounded-xl overflow-hidden hover:shadow-lg transition">
                    <div class="bg-eggShell h-40 flex items-center justify-center text-5xl">
                        {% if 'Oeuf' in produit|class_name %}
                            <i class="fa-solid fa-egg text-brand"></i>
                        {% elseif 'Viande' in produit|class_name %}
                            <i class="fa-solid fa-drumstick-bite text-amber-700"></i>
                        {% elseif 'Ticket' in produit|class_name %}
                            <i class="fa-solid fa-ticket text-green-600"></i>
                        {% elseif 'Nourriture' in produit|class_name %}
                            <i class="fa-solid fa-seedling text-green-500"></i>
                        {% else %}
                            <i class="fa-solid fa-box text-gray-400"></i>
                        {% endif %}
                    </div>
                    <div class="p-4">
                        <h3 class="font-semibold text-lg">{{ produit.nom }}</h3>
                        <p class="text-gray-500 text-sm mt-1">{{ produit.description|slice(0, 80) ~ (produit.description|length > 80 ? '...' : '') }}</p>
                        <div class="flex items-center justify-between mt-3">
                            <span class="font-bold text-lg text-brand">{{ produit.prix }} €{% if produit.prixUnite %} / {{ produit.prixUnite }}{% endif %}</span>
                            <a href="{{ path('app_catalogue_detail', {'id': produit.id}) }}" class="text-sm font-semibold text-farmGreen hover:underline">
                                Voir plus →
                            </a>
                        </div>
                    </div>
                </div>
            {% else %}
                <p class="col-span-full text-center text-gray-500 py-10">Aucun produit disponible pour le moment.</p>
            {% endfor %}
        </div>
        <div class="text-center mt-8">
            <a href="{{ path('app_catalogue') }}" class="inline-block text-farmGreen font-semibold hover:underline text-lg">
                Voir tout le catalogue →
            </a>
        </div>
    </section>

    {# Info section #}
    <section class="bg-eggShell py-12 px-6 md:px-12">
        <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
            <div>
                <i class="fa-solid fa-egg text-4xl text-brand mb-3"></i>
                <h3 class="font-bold text-lg mb-2">Œufs frais</h3>
                <p class="text-gray-600">Ramassés chaque matin, nos œufs sont garantis frais et de qualité.</p>
            </div>
            <div>
                <i class="fa-solid fa-hand-holding-heart text-4xl text-farmGreen mb-3"></i>
                <h3 class="font-bold text-lg mb-2">Élevage respectueux</h3>
                <p class="text-gray-600">Nos poules sont élevées en plein air et nourries sans OGM.</p>
            </div>
            <div>
                <i class="fa-solid fa-truck text-4xl text-farmGreenLight mb-3"></i>
                <h3 class="font-bold text-lg mb-2">Livraison locale</h3>
                <p class="text-gray-600">Livraison en circuit court pour une fraîcheur optimale.</p>
            </div>
        </div>
    </section>
</main>
{% endblock %}
