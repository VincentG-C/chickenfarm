{% extends 'layout/app.html.twig' %}

{% block content %}
<main class="max-w-4xl mx-auto px-6 md:px-12 py-8">
    <h1 class="text-3xl font-bold mb-6">Votre panier</h1>

    {% if panier and panier.produits|length > 0 %}
        <div class="space-y-4 mb-8">
            {% for item in panier.produits %}
                <div class="flex items-center justify-between border border-gray-200 rounded-xl p-4">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-eggShell rounded-lg flex items-center justify-center text-xl">
                            {% if 'oeuf' in item.produit|class_name|lower %}
                                <i class="fa-solid fa-egg text-brand"></i>
                            {% elseif 'viande' in item.produit|class_name|lower %}
                                <i class="fa-solid fa-drumstick-bite text-amber-700"></i>
                            {% elseif 'ticket' in item.produit|class_name|lower %}
                                <i class="fa-solid fa-ticket text-green-600"></i>
                            {% else %}
                                <i class="fa-solid fa-box text-gray-400"></i>
                            {% endif %}
                        </div>
                        <div>
                            <h3 class="font-semibold">{{ item.produit.nom }}</h3>
                            <p class="text-sm text-gray-500">{{ item.quantite }} × {{ item.produit.prix }} €</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="font-bold">{{ (item.quantite * item.produit.prix)|number_format(2) }} €</span>
                        <form action="{{ path('app_panier_supprimer', {'id': item.id}) }}" method="POST" onsubmit="return confirm('Retirer cet article du panier ?')">
                            <button type="submit" class="text-red-500 hover:text-red-700">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>

        <div class="border-t border-gray-200 pt-4 mb-8">
            <div class="flex items-center justify-between text-xl font-bold">
                <span>Total</span>
                <span>{{ panier.total|number_format(2) }} €</span>
            </div>
        </div>

        <div class="flex justify-between">
            <form action="{{ path('app_panier_vider') }}" method="POST">
                <button type="submit" class="text-gray-500 hover:text-red-600 border border-gray-300 px-6 py-2.5 rounded-full text-sm font-semibold transition">
                    <i class="fa-solid fa-trash-can mr-1"></i> Vider le panier
                </button>
            </form>
            <a href="{{ path('app_commande_valider') }}" class="bg-farmGreen text-white font-bold px-8 py-2.5 rounded-full hover:bg-farmGreenLight transition">
                Valider la commande →
            </a>
        </div>
    {% else %}
        <div class="text-center py-16">
            <i class="fa-solid fa-basket-shopping text-6xl text-gray-300 mb-4"></i>
            <p class="text-gray-500 text-lg mb-4">Votre panier est vide</p>
            <a href="{{ path('app_catalogue') }}" class="inline-block bg-farmGreen text-white font-bold px-8 py-3 rounded-full hover:bg-farmGreenLight transition">
                Découvrir nos produits
            </a>
        </div>
    {% endif %}
</main>
{% endblock %}
