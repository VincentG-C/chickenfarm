<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>🐔 Ferme des Poulettes – Produits frais de la ferme</title>
        <script src="https://cdn.tailwindcss.com"></script>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <script>
            tailwind.config = {
                theme: {
                    extend: {
                        colors: {
                            brand: '#E8A317',
                            brandHover: '#C88A10',
                            farmGreen: '#4A7C59',
                            farmGreenLight: '#6BA87A',
                            eggShell: '#FFF8E7',
                        }
                    }
                }
            }
        </script>
        {% block javascripts %}
            {{ importmap('app') }}
        {% endblock %}
    </head>

    {% block body %}{% endblock %}

</html>
