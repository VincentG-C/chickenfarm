<aside class="w-64 bg-gray-900 text-white flex flex-col justify-between hidden md:flex shrink-0">
    <div>
        <div class="p-5 border-b border-gray-800 flex items-center space-x-2 text-brand text-xl font-bold">
            <i class="fa-solid fa-egg text-2xl"></i>
            <span class="text-white text-sm tracking-wider uppercase font-semibold">Ferme Admin</span>
        </div>
        <nav class="p-4 space-y-1">
            <a href="{{ path('app_admin_home') }}" class="flex items-center space-x-3 {{ app.request.attributes.get('_route') == 'app_admin_home' ? 'bg-gray-800 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' }} px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-chart-pie text-brand"></i>
                <span>Tableau de bord</span>
            </a>

            <div class="text-gray-500 text-xs uppercase tracking-wider px-4 pt-4 pb-1">E-commerce</div>

            <a href="{{ path('app_produit_index') }}" class="flex items-center space-x-3 {{ app.request.attributes.get('_route') starts with 'app_produit' ? 'bg-gray-800 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' }} px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-box text-brand"></i>
                <span>Produits</span>
            </a>
            <a href="{{ path('app_order_index') }}" class="flex items-center space-x-3 {{ app.request.attributes.get('_route') starts with 'app_order' ? 'bg-gray-800 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' }} px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-receipt"></i>
                <span>Commandes</span>
            </a>
            <a href="{{ path('app_stock_index') }}" class="flex items-center space-x-3 {{ app.request.attributes.get('_route') starts with 'app_stock' ? 'bg-gray-800 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' }} px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-warehouse"></i>
                <span>Stocks</span>
            </a>

            <div class="text-gray-500 text-xs uppercase tracking-wider px-4 pt-4 pb-1">Gestion ferme</div>

            <a href="{{ path('app_manager_enclos') }}" class="flex items-center space-x-3 {{ app.request.attributes.get('_route') starts with 'app_manager_enclos' ? 'bg-gray-800 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' }} px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-egg"></i>
                <span>Enclos</span>
            </a>
            <a href="{{ path('app_manager_couveuses') }}" class="flex items-center space-x-3 {{ app.request.attributes.get('_route') starts with 'app_manager_couveuses' ? 'bg-gray-800 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' }} px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-microscope"></i>
                <span>Couveuses</span>
            </a>
            <a href="{{ path('app_manager_journal') }}" class="flex items-center space-x-3 {{ app.request.attributes.get('_route') starts with 'app_manager_journal' ? 'bg-gray-800 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' }} px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-book"></i>
                <span>Journal</span>
            </a>

            <div class="text-gray-500 text-xs uppercase tracking-wider px-4 pt-4 pb-1">Administration</div>

            <a href="{{ path('app_user_index') }}" class="flex items-center space-x-3 {{ app.request.attributes.get('_route') starts with 'app_user' ? 'bg-gray-800 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' }} px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-users"></i>
                <span>Utilisateurs</span>
            </a>
        </nav>
    </div>

    <div class="p-4 border-t border-gray-800 flex items-center space-x-3">
        <div class="w-9 h-9 bg-brand text-white rounded-full flex items-center justify-center font-bold text-sm">
            {{ app.user.prenom|first }}{{ app.user.nom|first }}
        </div>
        <div>
            <p class="text-xs font-semibold text-white">{{ app.user.prenom }} {{ app.user.nom }}</p>
            {% set role_label = app.user|class_name == 'Admin' ? 'Super Admin' : (app.user|class_name == 'Manager' ? 'Manager' : 'Utilisateur') %}
            <span class="text-[10px] text-emerald-400 font-medium"><i class="fa-solid fa-circle text-[8px] mr-1"></i> {{ role_label }}</span>
        </div>
    </div>
</aside>
