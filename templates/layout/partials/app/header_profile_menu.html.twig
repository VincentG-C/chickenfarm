<div class="relative group">
    <button class="flex items-center gap-2 py-1.5 px-3 rounded-full hover:bg-gray-50 border border-gray-200 transition" aria-label="Mon compte">
        <i class="fa-solid fa-circle-user text-xl text-gray-600"></i>
        <span class="hidden sm:inline text-sm font-medium text-gray-700 truncate max-w-[120px]">{{ app.user.prenom }} {{ app.user.nom }}</span>
    </button>

    <div class="absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
        <div class="p-3 border-b border-gray-100">
            <p class="text-sm font-semibold text-gray-900 truncate">{{ app.user.prenom }} {{ app.user.nom }}</p>
            <p class="text-xs text-gray-500 truncate">{{ app.user.email }}</p>
        </div>

        <div class="py-1">
            {% if is_granted('ROLE_MANAGER') or is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_manager_enclos') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">
                    <i class="fa-solid fa-warehouse w-5 text-gray-400"></i> Gestion ferme
                </a>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_admin_home') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">
                    <i class="fa-solid fa-gauge w-5 text-gray-400"></i> Administration
                </a>
            {% endif %}
            {% if is_granted('ROLE_USER') %}
                <a href="{{ path('app_commandes') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">
                    <i class="fa-solid fa-receipt w-5 text-gray-400"></i> Mes commandes
                </a>
            {% endif %}
        </div>

        <div class="border-t border-gray-100 py-1">
            <a href="{{ path('app_logout') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-red-50 hover:text-red-600">
                <i class="fa-solid fa-right-from-bracket w-5 text-gray-400"></i> Déconnexion
            </a>
        </div>
    </div>
</div>
